DOCKER_IMAGE=jaykserks/summerain:1.2.3

SERVER_PORT=8080
GIN_MODE=release
COOKIE_SECRET=change-me-in-production
# Required for the wasm-vips large-image path. Disabling isolation prevents
# large images above the native browser safety limit from being processed.
# Third-party frontend resources must opt in through CORS or CORP under COEP.
CROSS_ORIGIN_ISOLATION=true

DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=summerain
# Bound connection pools for shared, memory-constrained hosts.
DB_MAX_OPEN_CONNS=8
DB_MAX_IDLE_CONNS=4
DB_CONN_MAX_LIFETIME=30m

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=8

IMGPROXY_URL=http://imgproxy:8080
IMGPROXY_KEY=replace_with_hex_key
IMGPROXY_SALT=replace_with_hex_salt
IMGPROXY_PUBLIC_URL=/img
IMGPROXY_LOCAL_FILESYSTEM_ROOT=/data
IMGPROXY_WORKERS=2

# Durable V2 CDN invalidation. Cloudflare is preferred when both credentials
# are set; otherwise the generic webhook is used. Leave both delivery methods
# empty to retain purge events as pending (they are never reported as purged).
# Required when either delivery method is enabled, for example https://images.example.com.
CDN_PUBLIC_BASE_URL=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_API_BASE_URL=https://api.cloudflare.com/client/v4
CDN_PURGE_WEBHOOK_URL=
CDN_PURGE_WEBHOOK_TOKEN=
OUTBOX_BATCH_SIZE=10
OUTBOX_POLL_INTERVAL=2s
OUTBOX_LEASE=3m
CDN_PURGE_REQUESTS_PER_SECOND=4
CDN_PURGE_REQUEST_TIMEOUT=15s

STORAGE_PATH=/data/images
# Staging must stay on the image volume so finalization can use atomic rename.
TEMP_PATH=/data/images/.staging
DISK_SOFT_LIMIT_PERCENT=80
DISK_HARD_LIMIT_PERCENT=90
V2_STAGING_PATH=/data/images/.staging
V2_UPLOAD_ENABLED=true
V2_RECIPE_VERSION=2.0.0
V2_MAX_PART_BYTES=67108864
V2_MAX_PIXELS=50000000
V2_SESSION_TTL=30m
V2_GLOBAL_UPLOAD_CONCURRENCY=8
V2_PER_USER_UPLOAD_CONCURRENCY=4
V2_WATERMARK_CONCURRENCY=2
V2_JOB_POLL_INTERVAL=1s
V2_JOB_LEASE=2m

# Captcha provider: none | recaptcha | turnstile | geetest_v4
CAPTCHA_PROVIDER=none

RECAPTCHA_ENABLED=false
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_VERIFY_URL=https://www.recaptcha.net/recaptcha/api/siteverify
RECAPTCHA_FAIL_CLOSED=true
RECAPTCHA_ALLOWED_HOSTNAMES=

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# GeeTest v4
GEETEST_CAPTCHA_ID=
GEETEST_CAPTCHA_KEY=
GEETEST_VERIFY_URL=https://gcaptcha4.geetest.com/verify
