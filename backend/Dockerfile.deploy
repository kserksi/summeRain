FROM alpine:3.19
RUN apk --no-cache add ca-certificates tzdata && \
    adduser -D -u 10001 app
ENV TZ=Asia/Shanghai
WORKDIR /app
COPY backend/server .
COPY web/build/web/ ./web/
RUN chmod +x server && \
    mkdir -p /data/images /data/temp && \
    chown -R 10001:10001 /app /data
USER 10001
EXPOSE 8080
ENTRYPOINT ["./server"]